{
  "ConnectionStrings": {
    "TransactionsDb": "Server=sqlserver,1433;Database=TransactionsDb;User Id=sa;Password=${SQL_SERVER_PASSWORD};TrustServerCertificate=True;"
  },
  "JwtSettings": {
    "Secret": "${JWT_SECRET}",
    "Issuer": "BankingSystem.Transactions",
    "Audience": "BankingSystem.Clients"
  },
  "Services": {
    "ClientsService": {
      "BaseUrl": "${CLIENTS_SERVICE_BASE_URL}"
    }
  },
  "ServiceBus": {
    "ConnectionString": "${AZURE_SERVICE_BUS_CONNECTION_STRING}"
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information"
      }
    }
  },
  "AllowedHosts": "*"
}
