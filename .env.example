# ============================================================
# Banking System — Environment Variables Example
# Copy this file to .env and fill in the real values.
# NEVER commit the .env file to source control.
# ============================================================

# ── SQL Server ───────────────────────────────────────────────
# Minimum 8 chars, must contain uppercase, lowercase, digit and symbol
SQL_SERVER_PASSWORD=YourStr0ng!Passw0rd

# ── Redis ────────────────────────────────────────────────────
REDIS_PASSWORD=YourRedisPassword123

# ── JWT ──────────────────────────────────────────────────────
# Min 32 chars — use: openssl rand -hex 32
JWT_SECRET=replace_me_with_a_32_char_or_longer_random_secret

# ── Azure Service Bus ────────────────────────────────────────
# Get from Azure Portal → Service Bus Namespace → Shared Access Policies
AZURE_SERVICE_BUS_CONNECTION_STRING=Endpoint=sb://your-namespace.servicebus.windows.net/;SharedAccessKeyName=RootManageSharedAccessKey;SharedAccessKey=your_key

# ── Azure Blob Storage ───────────────────────────────────────
# Get from Azure Portal → Storage Account → Access Keys
AZURE_BLOB_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=youraccount;AccountKey=yourkey;EndpointSuffix=core.windows.net

# ── SendGrid ─────────────────────────────────────────────────
# Get from SendGrid → Settings → API Keys
SENDGRID_API_KEY=SG.your_sendgrid_api_key
SENDGRID_FROM_EMAIL=noreply@yourdomain.com

# ── Clients Service (used by Transactions service) ───────────
# In local Docker Compose this is set automatically.
# Override only when running outside Docker.
CLIENTS_SERVICE_BASE_URL=http://localhost:5002
